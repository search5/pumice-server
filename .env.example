# Obsidian gRPC Sync Server environment configuration example

# HTTP + gRPC-Web server port (default: 8080) — the client communicates through this single port only
HTTP_PORT=8080

# Path to the sync data storage directory
DATA_DIR=~/.obsidian-sync-server

# Required: the server refuses to start without both of these set. Seeds the first (admin)
# account on first startup -- there's no other way to provision an account.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Database type to use (sqlite, json, mysql, mariadb, postgresql, cubrid)
DB_TYPE=sqlite

# ------------------------------------------------------------------------------
# 1. SQLite-only settings (when DB_TYPE=sqlite)
# ------------------------------------------------------------------------------
# Filename (or absolute path) of the SQLite3 database file to create
DB_NAME=sync_metadata.db

# ------------------------------------------------------------------------------
# 2. External DB-only settings (when DB_TYPE is mysql, mariadb, postgresql, or cubrid)
# ------------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306      # MySQL/MariaDB: 3306, PostgreSQL: 5432, CUBRID: 33000
DB_USER=root
DB_PASSWORD=secret
# Name of the database schema to create/connect to when using an external DB
# DB_NAME=obsidian_sync
